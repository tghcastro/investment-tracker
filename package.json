{
  "engines": {
    "node": ">=22 <23"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev -w @investment-tracker/api",
    "dev:web": "bash scripts/dev-web.sh",
    "dev:web:sudo": "bash scripts/dev-web-sudo.sh",
    "lint": "node scripts/lint-monorepo.mjs",
    "check:docs": "node scripts/check-docs-freshness.mjs",
