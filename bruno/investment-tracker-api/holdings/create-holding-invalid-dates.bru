meta {
  name: Create Holding (invalid dates)
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/holdings
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "accountId": "{{accountId}}",
    "issuer": "Bad Dates Corp",
    "faceValue": 10000,
    "couponRate": 3.5,
    "couponFrequency": "annual",
    "maturityDate": "2024-01-01",
    "purchaseDate": "2024-06-01"
  }
}
