meta {
  name: Create Account
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/accounts
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Bruno Test Broker",
    "description": "Manual test account"
  }
}

script:post-response {
  if (res.status === 201 && res.body && res.body.id) {
    bru.setEnvVar("accountId", String(res.body.id));
  }
}
